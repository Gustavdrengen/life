{
  "name": "particle-ecosystem-simulator",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Browser-based WebGPU particle ecosystem simulator. All behavior emerges from per-particle genomes.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --max-warnings=0 .",
    "format": "prettier --write \"src/**/*.{ts,svelte,css}\" \"tests/**/*.ts\" \"specs/**/*.md\" \"*.md\"",
    "typecheck": "tsc --noEmit",
    "export:html": "node tools/export-singlefile.mjs dist/ecosystem.html"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@webgpu/types": "^0.1.40",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.42.0",
    "globals": "^15.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "prettier-plugin-svelte": "^3.2.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "tslib": "^2.7.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "svelte-eslint-parser": "^1.8.0"
  }
}
